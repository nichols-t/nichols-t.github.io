{
    "extends": [
      "react-app",
      "airbnb",
      "plugin:jsx-a11y/recommended"
    ],
    "plugins": [
      "jsx-a11y"
    ],
    "rules": {
        "linebreak-style": "off",
        "quotes": ["error", "single"],
      "react/jsx-filename-extension": [1, { "extensions": [".js", ".jsx"] }],
      "react/jsx-props-no-spreading": [1, { "custom": "ignore" }],
      "react/prop-types": 0
    }
  }
  